{
  "schema_version": "1.0",
  "product_id": "teacher",
  "product_name": "TeacherTasksAI",
  "official_domain": "teachertasksai.com",
  "official_github_repo": "https://github.com/laudoluxDev/teachertasksai-mcp",
  "official_package": "@tasksai/install",
  "installer": {
    "preferred": "npm_exec",
    "npm_exec": {
      "command": "npm",
      "args": [
        "exec",
        "--package=@tasksai/install",
        "--call",
        "tasksai-install teacher --source https://github.com/laudoluxDev/teachertasksai-mcp"
      ],
      "requires": [
        "node",
        "npm"
      ]
    }
  },
  "supported_clients": [
    "claude_desktop",
    "cursor",
    "windsurf",
    "codex"
  ],
  "auth": {
    "method": "browser_device_flow",
    "connect_url": "https://teachertasksai.com/connect",
    "fallback": "license_key"
  },
  "security": {
    "require_domain_verification": true,
    "require_repo_verification": true,
    "disallow_arbitrary_manifest_commands": true,
    "native_installer_user_approval_required": true
  },
  "health_check": {
    "command": "npm",
    "args": [
      "exec",
      "--package=@tasksai/install",
      "--call",
      "tasksai-install teacher doctor"
    ]
  },
  "uninstall": {
    "command": "npm",
    "args": [
      "exec",
      "--package=@tasksai/install",
      "--call",
      "tasksai-install teacher uninstall"
    ]
  },
  "support": {
    "url": "https://teachertasksai.com/support",
    "email": "support@teachertasksai.com"
  },
  "runtime": {
    "source": "shared_installer",
    "notes": "The wrapper repo provides product metadata; @tasksai/install supplies the shared MCP runtime."
  }
}
